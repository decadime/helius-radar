{
  "name": "helius-radar",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "prisma migrate deploy && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",

    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force --skip-seed",
    "db:studio": "prisma studio",

    "discover:vcs": "tsx scripts/discover-vcs.ts",
    "discover:defillama": "tsx scripts/discover-defillama.ts",
    "discover:helius": "tsx scripts/discover-helius.ts",
    "discover:all": "npm run discover:defillama && npm run discover:vcs && npm run discover:helius",
    "detect:rpc": "tsx scripts/detect-rpc-providers.ts",

    "import:candidates": "tsx scripts/import-candidates.ts",
    "import:signals": "tsx scripts/import-signals.ts",
    "import:matches": "tsx scripts/import-matches.ts",
    "generate:targets": "tsx scripts/generate-targets.ts",
    "seed": "npm run import:candidates && npm run import:signals && npm run import:matches && npm run generate:targets",

    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "clsx": "^2.1.1",
    "next": "^14.2.35",
    "openai": "^6.34.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.4.38",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.19.2",
    "typescript": "^5.4.5",
    "vitest": "^2.1.9"
  }
}
