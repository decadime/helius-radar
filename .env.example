# ─── Database ─────────────────────────────────────────────────────────────────
# Copy to `.env` and adjust for your environment.
#
# Local Postgres (native install):
#   DATABASE_URL="postgresql://<user>@localhost:5432/helius_radar?schema=public"
#
# Docker Postgres (see docker-compose.yml):
#   DATABASE_URL="postgresql://helius:helius@localhost:5432/helius_radar?schema=public"
DATABASE_URL="postgresql://helius:helius@localhost:5432/helius_radar?schema=public"

# ─── LLM enrichment (optional) ────────────────────────────────────────────────
# When USE_LLM=true, the daily target generator and VC discovery script enrich
# output via the configured model. Any LLM failure silently falls back to the
# deterministic path (target generator) or skips the source (VC discovery).
#
# CI runs with USE_LLM unset.
USE_LLM=false

# OpenRouter is OpenAI-compatible and gives access to Kimi K2, Claude,
# Gemini, etc. through one key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=moonshotai/kimi-k2
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1   # only override for self-host

# ─── Helius RPC (optional, required for discover:helius) ──────────────────────
# Free key: https://dashboard.helius.dev
# Used by the Helius-native on-chain discovery script to query the DAS API.
# Not needed for DefiLlama or VC discovery.
HELIUS_API_KEY=
